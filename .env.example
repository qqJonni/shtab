DATABASE_URL=postgresql://user:password@localhost/shtab
SECRET_KEY=change-me

# Web Push (сгенерировать VAPID-пару, см. pywebpush)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=admin@example.com

# ИИ-фолбэк для смет
# Провайдер: stub (локально, без сети) | yandexgpt | gigachat
AI_PROVIDER=stub

# YandexGPT (нужны только когда AI_PROVIDER=yandexgpt)
YANDEX_GPT_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_GPT_MODEL=yandexgpt/latest
